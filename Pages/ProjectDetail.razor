@page "/project/{ProjectId}"
@using TechArtPortfolio.Layout.Models
@using Markdig

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6 mb-16">
    
    <MudButton Href="/" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" Class="mb-6">
        Back To Home
    </MudButton>

    @if (CurrentProject == null)
    {
        <MudText Typo="Typo.h4" Color="Color.Error">Project not found.</MudText>
    }
    else
    {
        <MudText Typo="Typo.h2" Color="Color.Primary" GutterBottom="true" Style="font-weight: 700;">
            @CurrentProject.Title
        </MudText>
        <MudText Typo="Typo.h5" Color="Color.Secondary" Class="mb-8">
            @CurrentProject.Tagline
        </MudText>

        @foreach (var content in CurrentProject.Contents)
        {
            @if (content is TextContent textBlock)
            {
                <MudText Typo="Typo.body1" Class="my-6" Style="line-height: 1.6;">
                    @((MarkupString)Markdown.ToHtml(textBlock.Text, Pipeline))
                </MudText>
            }
            
            else if (content is ImageContent imgBlock)
            {
                <MudCard Elevation="0" 
                         Class="border-solid border-b-4 mud-border-secondary my-8 rounded-lg overflow-hidden"
                         Style="@(imgBlock.EnableOverflow ? "width: 100%;" : "width: 56.25%;")">
                    
                    <img src="@imgBlock.ImageUrl" 
                         style="pointer-events: none; @(imgBlock.EnableOverflow 
                                    ? "width: 100%; height: auto; aspect-ratio: 16/9; object-fit: cover; display: block;" 
                                    : "width: 100%; height: auto; display: block;")" />

                    @if (!string.IsNullOrWhiteSpace(imgBlock.Caption))
                    {
                        <MudCardContent>
                            <MudText Typo="Typo.body2" Color="Color.Primary" Style="opacity: 1;">@imgBlock.Caption</MudText>
                        </MudCardContent>
                    }
                </MudCard>
            }
            
            else if (content is VideoContent vidBlock)
            {
                <MudCard Elevation="0" Class="border-solid border-b-4 mud-border-secondary overflow-hidden my-8 rounded-lg">

                    <video autoplay loop muted playsinline style="pointer-events: none; width: 100%; display: block;">
                        <source src="@vidBlock.VideoUrl" type="video/mp4">
            
                        Your browser does not support the video tag.
                    </video>

                    @if (!string.IsNullOrWhiteSpace(vidBlock.Caption))
                    {
                        <MudCardContent>
                            <MudText Typo="Typo.body2" Color="Color.Primary" Style="opacity: 1;">@vidBlock.Caption</MudText>
                        </MudCardContent>
                    }

                </MudCard>
            }
            
            else if (content is CodeSnippetContent codeBlock)
            {
                <MudPaper Elevation="0" Class="pa-4 my-8 rounded-lg" Style="background-color: #2C3011; border: 1px solid #3E4018;">
        
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2 d-block">
                        @codeBlock.Language.ToUpper()
                    </MudText>  
        
                    <pre style="margin: 0; overflow-x: auto;">
            <code style="font-family: 'Consolas', 'Courier New', monospace; color: #FAF7EB;">@codeBlock.Code</code>
        </pre>
                </MudPaper>
            }
            
            else if (content is LinkButtonContent linkBlock)
            {
                <div class="my-6">
                    <MudButton Href="@linkBlock.Url" 
                               Target="_blank" 
                               Variant="Variant.Filled" 
                               Color="Color.Primary" 
                               EndIcon="@Icons.Material.Filled.OpenInNew">
                        @linkBlock.Caption
                    </MudButton>
                </div>
            }
            
            else if (content is EmbeddedVideoContent embedBlock)
            {
                <MudCard Elevation="0" Class="border-solid border-b-4 mud-border-secondary overflow-hidden my-8 rounded-lg">
                    
                    <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden;">
                        
                        <iframe style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;" 
                                src="@embedBlock.VideoUrl" 
                                title="Embedded video player" 
                                frameborder="0" 
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                                allowfullscreen>
                        </iframe>
                    </div>
                </MudCard>
            }
        }
    }
</MudContainer>

@code {
    [Parameter]
    public string ProjectId { get; set; }
    
    private Project? CurrentProject;
    
    private static readonly MarkdownPipeline Pipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    protected override void OnParametersSet()
    {
        CurrentProject = PortfolioData.GetProjectById(ProjectId);
    }
}
